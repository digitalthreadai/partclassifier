# ── LLM Provider Configuration ──
# Supported providers: groq, openai, anthropic, ollama, custom
LLM_PROVIDER=groq

# API key for your chosen provider
LLM_API_KEY=your_api_key_here

# Model name (optional — each provider has a sensible default)
# Groq default:      llama-3.3-70b-versatile
# OpenAI default:    gpt-4o
# Anthropic default: claude-sonnet-4-20250514
# Ollama default:    llama3.1
#LLM_MODEL=

# Custom provider endpoint (only needed when LLM_PROVIDER=custom)
#LLM_BASE_URL=https://your-api.com/v1

# ── Legacy (still works) ──
# If LLM_PROVIDER is not set, the agent falls back to GROQ_API_KEY
#GROQ_API_KEY=your_groq_api_key_here

# ── Distributor API Keys (all optional) ──
# If configured, these APIs are queried before web scraping for higher-quality data.

# DigiKey Product Information API v4 (free: https://developer.digikey.com)
#DIGIKEY_CLIENT_ID=your_client_id
#DIGIKEY_CLIENT_SECRET=your_client_secret

# Mouser Search API (free: https://api.mouser.com)
#MOUSER_API_KEY=your_api_key

# McMaster-Carr Product Information API (email eprocurement@mcmaster.com for access)
#MCMASTER_BEARER_TOKEN=your_token
#MCMASTER_CLIENT_CERT=path/to/client.pem
#MCMASTER_CLIENT_KEY=path/to/client-key.pem

# ── Stealth Browser (optional) ──
# CloakBrowser: stealth Chromium for bot-protected sites (McMaster-Carr).
# Install: pip install cloakbrowser  (downloads ~200MB Chromium binary on first use)
# Set to "false" to disable even if installed.
#STEALTH_BROWSER_ENABLED=true
