# ══════════════════════════════════════════════════════════════════════════════
# PartClassifier — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Only LLM_PROVIDER and LLM_API_KEY are required (except for bedrock/ollama).

# ── LLM Provider (REQUIRED) ──────────────────────────────────────────────────
# Choose ONE provider:
#   groq            - Groq API (free tier, fast)          Needs: LLM_API_KEY
#   openai          - OpenAI API (GPT-4o, etc.)           Needs: LLM_API_KEY
#   anthropic       - Anthropic API (Claude direct)       Needs: LLM_API_KEY
#   azure_openai    - Azure-hosted GPT models             Needs: LLM_API_KEY + AZURE_* vars
#   azure_anthropic - Azure-hosted Claude (via proxy)     Needs: LLM_API_KEY + LLM_BASE_URL
#   bedrock         - AWS Bedrock native (Anthropic SDK)  Needs: AWS credentials (no API key)
#   bedrock_openai  - AWS Bedrock via OpenAI proxy        Needs: LLM_API_KEY + LLM_BASE_URL
#   ollama          - Local Ollama server                 Needs: nothing (localhost)
#   custom          - Any OpenAI-compatible endpoint      Needs: LLM_API_KEY + LLM_BASE_URL
LLM_PROVIDER=groq

# ── API Key (REQUIRED for most providers) ────────────────────────────────────
# Not needed for: bedrock (uses AWS credentials), ollama (local)
LLM_API_KEY=your_api_key_here

# ── Model Override (OPTIONAL) ────────────────────────────────────────────────
# Each provider has a sensible default. Override only if needed.
# Defaults:
#   groq:            llama-3.3-70b-versatile
#   openai:          gpt-4o
#   anthropic:       claude-sonnet-4-20250514
#   azure_openai:    gpt-4o (or AZURE_OPENAI_DEPLOYMENT)
#   azure_anthropic: claude-sonnet-4-20250514
#   bedrock:         anthropic.claude-sonnet-4-20250514-v1:0
#   bedrock_openai:  anthropic.claude-sonnet-4-20250514-v1:0
#   ollama:          llama3.1
#LLM_MODEL=

# ── Custom/Proxy Endpoint (REQUIRED for: custom, bedrock_openai, azure_anthropic) ──
# Must be an OpenAI-compatible /v1/chat/completions endpoint.
# Examples:
#   bedrock_openai:  https://your-company-bedrock-proxy.com/v1
#   azure_anthropic: https://your-azure-claude-proxy.com/v1
#   custom:          https://your-llm-gateway.com/v1
#LLM_BASE_URL=

# ══════════════════════════════════════════════════════════════════════════════
# ENTERPRISE CONFIGURATIONS
# ══════════════════════════════════════════════════════════════════════════════

# ── Azure OpenAI (GPT models via Azure) ──────────────────────────────────────
# Use when: Your company hosts GPT-4o/GPT-4-turbo on Azure
# Set LLM_PROVIDER=azure_openai
#AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
#AZURE_OPENAI_API_VERSION=2024-12-01-preview
#AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# ── Azure Anthropic (Claude models via Azure proxy) ──────────────────────────
# Use when: Your company hosts Claude on Azure behind an OpenAI-compatible proxy
# Set LLM_PROVIDER=azure_anthropic
# Set LLM_BASE_URL=https://your-azure-proxy.company.com/v1
# Set LLM_API_KEY=your-azure-api-key
# Set LLM_MODEL=claude-sonnet-4-20250514 (optional)

# ── AWS Bedrock Native (Claude via Anthropic SDK) ────────────────────────────
# Use when: You have direct AWS Bedrock access with IAM credentials
# Set LLM_PROVIDER=bedrock
# No LLM_API_KEY needed — uses AWS credential chain:
#   1. AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY env vars
#   2. ~/.aws/credentials profile
#   3. IAM instance role (on EC2/ECS)
#AWS_REGION=us-east-1

# ── AWS Bedrock via OpenAI Proxy (enterprise gateway) ────────────────────────
# Use when: Your company has a proxy/gateway that exposes Bedrock as OpenAI API
# This is common in enterprises that standardize on OpenAI SDK across all LLMs.
# Set LLM_PROVIDER=bedrock_openai
# Set LLM_BASE_URL=https://your-bedrock-proxy.company.com/v1
# Set LLM_API_KEY=your-proxy-api-key

# ── Legacy (backward compatible) ────────────────────────────────────────────
# If LLM_PROVIDER is not set, falls back to GROQ_API_KEY
#GROQ_API_KEY=your_groq_api_key_here

# ══════════════════════════════════════════════════════════════════════════════
# DISTRIBUTOR API KEYS (all optional)
# ══════════════════════════════════════════════════════════════════════════════
# If configured, these APIs are queried BEFORE web scraping for structured data.

# DigiKey Product Information API v4 (free: https://developer.digikey.com)
#DIGIKEY_CLIENT_ID=your_client_id
#DIGIKEY_CLIENT_SECRET=your_client_secret

# Mouser Search API (free: https://api.mouser.com)
#MOUSER_API_KEY=your_api_key

# McMaster-Carr Product Information API (email eprocurement@mcmaster.com)
#MCMASTER_BEARER_TOKEN=your_token
#MCMASTER_CLIENT_CERT=path/to/client.pem
#MCMASTER_CLIENT_KEY=path/to/client-key.pem

# ══════════════════════════════════════════════════════════════════════════════
# STEALTH BROWSER (optional)
# ══════════════════════════════════════════════════════════════════════════════
# CloakBrowser: stealth Chromium for bot-protected sites (McMaster-Carr, etc.)
# Install: pip install cloakbrowser (downloads ~200MB Chromium binary on first use)
# Set to "false" to disable even if installed.
#STEALTH_BROWSER_ENABLED=true
