# ── LLM Provider Configuration ──
# Supported providers: groq, openai, anthropic, ollama, custom
LLM_PROVIDER=groq

# API key for your chosen provider
LLM_API_KEY=your_api_key_here

# Model name (optional — each provider has a sensible default)
# Groq default:      llama-3.3-70b-versatile
# OpenAI default:    gpt-4o
# Anthropic default: claude-sonnet-4-20250514
# Ollama default:    llama3.1
#LLM_MODEL=

# Custom provider endpoint (only needed when LLM_PROVIDER=custom)
#LLM_BASE_URL=https://your-api.com/v1

# ── Legacy (still works) ──
# If LLM_PROVIDER is not set, the agent falls back to GROQ_API_KEY
#GROQ_API_KEY=your_groq_api_key_here
