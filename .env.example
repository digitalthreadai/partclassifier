# ══════════════════════════════════════════════════════════════════════════════
# PartClassifier — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ┌─────────────────────────────────────────────────────────────────────────────
# │ QUICK REFERENCE: Which provider should I use?
# ├─────────────────────────────────────────────────────────────────────────────
# │ Scenario                        │ LLM_PROVIDER    │ Required Vars
# │─────────────────────────────────│─────────────────│──────────────────────
# │ Free/fast (recommended start)   │ groq            │ LLM_API_KEY
# │ OpenAI direct (GPT-4o)          │ openai          │ LLM_API_KEY
# │ Anthropic direct (Claude)       │ anthropic       │ LLM_API_KEY
# │ Azure + GPT models              │ azure_openai    │ LLM_API_KEY + AZURE_OPENAI_ENDPOINT
# │ Azure + Claude models           │ azure_openai    │ LLM_API_KEY + AZURE_OPENAI_ENDPOINT + LLM_MODEL
# │ AWS Bedrock (native)            │ bedrock         │ AWS credentials (no API key)
# │ AWS Bedrock (via proxy)         │ bedrock_openai  │ LLM_API_KEY + LLM_BASE_URL
# │ Local models (Ollama)           │ ollama          │ (none)
# │ Any OpenAI-compatible proxy     │ custom          │ LLM_API_KEY + LLM_BASE_URL
# └─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED: Provider ────────────────────────────────────────────────────────
LLM_PROVIDER=groq

# ── REQUIRED: API Key (for most providers) ────────────────────────────────────
# Not needed for: bedrock (uses AWS creds), ollama (local)
LLM_API_KEY=your_api_key_here

# ── OPTIONAL: Model Override ──────────────────────────────────────────────────
# Each provider has a sensible default. Only set if you need a specific model.
#LLM_MODEL=

# ── OPTIONAL: Custom Endpoint ─────────────────────────────────────────────────
# REQUIRED for: bedrock_openai, custom
# Must be an OpenAI-compatible /v1/chat/completions endpoint.
#LLM_BASE_URL=

# ══════════════════════════════════════════════════════════════════════════════
# ENTERPRISE CONFIGURATIONS
# ══════════════════════════════════════════════════════════════════════════════

# ── Azure + GPT (e.g., GPT-4o on Azure) ──────────────────────────────────────
# LLM_PROVIDER=azure_openai
# LLM_API_KEY=your-azure-api-key                              (REQUIRED)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/  (REQUIRED)
# AZURE_OPENAI_API_VERSION=2024-12-01-preview                 (optional, has default)
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name                (optional, falls back to LLM_MODEL)

# ── Azure + Claude (Claude deployed on Azure) ────────────────────────────────
# Azure wraps Claude in the same OpenAI format as GPT. Use azure_openai provider.
# LLM_PROVIDER=azure_openai
# LLM_API_KEY=your-azure-api-key                              (REQUIRED)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/  (REQUIRED)
# LLM_MODEL=claude-sonnet-4-20250514                     (REQUIRED - specify Claude model)
# AZURE_OPENAI_DEPLOYMENT=your-claude-deployment              (optional)
# Note: You may need to disable SSL verification if your Azure endpoint
# uses internal certificates. Set CURL_CA_BUNDLE="" or use --no-verify.

# ── AWS Bedrock Native (direct Anthropic SDK) ────────────────────────────────
# Use when you have direct AWS Bedrock access with IAM credentials.
# LLM_PROVIDER=bedrock
# AWS_REGION=us-east-1                                         (optional, defaults to us-east-1)
# No LLM_API_KEY needed. Uses AWS credential chain:
#   1. AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY env vars
#   2. ~/.aws/credentials profile
#   3. IAM instance role (on EC2/ECS/Lambda)

# ── AWS Bedrock via Proxy (OpenAI-compatible gateway) ─────────────────────────
# Use when your company has a proxy that exposes Bedrock as OpenAI API.
# Common in enterprises that standardize on the OpenAI SDK across all LLMs.
# LLM_PROVIDER=bedrock_openai
# LLM_API_KEY=your-proxy-api-key                               (REQUIRED)
# LLM_BASE_URL=https://your-bedrock-proxy.company.com/v1       (REQUIRED)
# LLM_MODEL=anthropic.claude-sonnet-4-20250514-v1:0       (optional, has default)

# ── Ollama (local, free) ─────────────────────────────────────────────────────
# LLM_PROVIDER=ollama
# No API key or endpoint needed. Requires: ollama serve running locally.

# ── Legacy (backward compatible) ─────────────────────────────────────────────
# If LLM_PROVIDER is not set, falls back to GROQ_API_KEY
#GROQ_API_KEY=your_groq_api_key_here

# ══════════════════════════════════════════════════════════════════════════════
# DISTRIBUTOR API KEYS (all optional)
# ══════════════════════════════════════════════════════════════════════════════
# If configured, these APIs are queried BEFORE web scraping for structured data.

# DigiKey Product Information API v4 (free: https://developer.digikey.com)
#DIGIKEY_CLIENT_ID=your_client_id
#DIGIKEY_CLIENT_SECRET=your_client_secret

# Mouser Search API (free: https://api.mouser.com)
#MOUSER_API_KEY=your_api_key

# McMaster-Carr Product Information API (email eprocurement@mcmaster.com)
#MCMASTER_BEARER_TOKEN=your_token
#MCMASTER_CLIENT_CERT=path/to/client.pem
#MCMASTER_CLIENT_KEY=path/to/client-key.pem

# ══════════════════════════════════════════════════════════════════════════════
# STEALTH BROWSER (optional)
# ══════════════════════════════════════════════════════════════════════════════
# CloakBrowser: stealth Chromium for bot-protected sites (McMaster-Carr, etc.)
# Install: pip install cloakbrowser (downloads ~200MB Chromium binary)
# Set to "false" to disable even if installed.
#STEALTH_BROWSER_ENABLED=true
